<!-- Footer -->
<footer data-aos="fade-up" data-aos-duration="600"
  class="border-t border-gray-200 dark:border-gray-800 py-5 px-6 text-center
  text-gray-400 dark:text-gray-500 text-sm rounded-t-2xl bg-white dark:bg-gray-900 mx-4 mb-4">
  Built with <span class="text-red-500">&#10084;</span> by
  <a href="https://github.com/mauricegift" target="_blank"
    class="text-indigo-500 hover:text-indigo-600 no-underline font-medium">mauricegift</a>
  &nbsp;&middot;&nbsp;
  <a href="https://github.com/mauricegift/free-proxies" target="_blank"
    class="text-indigo-500 hover:text-indigo-600 no-underline">View on GitHub</a>
  &nbsp;&middot;&nbsp;
  Auto-updated every 30 minutes
  &nbsp;&middot;&nbsp;
  <a href="https://pages.github.com" target="_blank"
    class="inline-flex items-center gap-1 text-indigo-500 hover:text-indigo-600 no-underline">
    <i class="fa-brands fa-github text-xs"></i> Hosted on GitHub Pages
  </a>
</footer>
</main>

<!-- Toast -->
<div id="toast"
  class="fixed bottom-6 right-6 z-50 opacity-0 translate-y-2 pointer-events-none
  transition-all duration-300 bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900
  text-sm font-medium px-4 py-2.5 rounded-xl shadow-xl">
  Copied!
</div>

<script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
<script>
  AOS.init({
    duration: 700,
    once: false,
    mirror: true,
    easing: 'ease-in-out',
    offset: 60,
  });

  fetch('https://api.github.com/repos/mauricegift/free-proxies')
    .then(r => r.json())
    .then(d => {
      if (d.stargazers_count != null) document.getElementById('star-count').textContent = d.stargazers_count.toLocaleString();
      if (d.forks_count != null) document.getElementById('fork-count').textContent = d.forks_count.toLocaleString();
    }).catch(() => {});

  function toggleTheme() {
    const dark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', dark ? 'dark' : 'light');
    updateThemeIcon(dark);
  }
  function updateThemeIcon(dark) {
    document.getElementById('theme-icon').className = dark ? 'fa-solid fa-moon' : 'fa-solid fa-sun';
  }
  updateThemeIcon(document.documentElement.classList.contains('dark'));

  function toggleSidebar() {
    document.getElementById('sidebar').classList.toggle('-translate-x-full');
    document.getElementById('overlay').classList.toggle('hidden');
    document.body.classList.toggle('overflow-hidden');
  }
  function closeSidebar() {
    document.getElementById('sidebar').classList.add('-translate-x-full');
    document.getElementById('overlay').classList.add('hidden');
    document.body.classList.remove('overflow-hidden');
  }

  const _secs = document.querySelectorAll('section[id]');
  const _lnks = document.querySelectorAll('.nav-link');
  const _dlnks = document.querySelectorAll('.desktop-nav-link');
  window.addEventListener('scroll', () => {
    let cur = '';
    _secs.forEach(s => { if (window.scrollY >= s.offsetTop - 90) cur = s.id; });
    _lnks.forEach(l => {
      const on = l.dataset.section === cur;
      l.classList.toggle('bg-indigo-500', on);
      l.classList.toggle('!text-white', on);
    });
    _dlnks.forEach(l => {
      const section = l.getAttribute('href').replace('#','');
      const on = section === cur;
      l.classList.toggle('bg-indigo-500', on);
      l.classList.toggle('!text-white', on);
      l.classList.toggle('text-gray-600', !on);
      l.classList.toggle('dark:text-gray-400', !on);
    });
  }, { passive: true });

  function copy(id, btn) {
    navigator.clipboard.writeText(document.getElementById(id).textContent.trim()).then(() => {
      const orig = btn.textContent;
      btn.textContent = 'Copied!';
      btn.classList.replace('bg-indigo-500', 'bg-emerald-500');
      setTimeout(() => { btn.textContent = orig; btn.classList.replace('bg-emerald-500', 'bg-indigo-500'); }, 2000);
      const t = document.getElementById('toast');
      t.classList.remove('opacity-0', 'translate-y-2');
      t.classList.add('opacity-100', 'translate-y-0');
      setTimeout(() => { t.classList.add('opacity-0', 'translate-y-2'); t.classList.remove('opacity-100', 'translate-y-0'); }, 2200);
    });
  }
</script>
</body>
</html>